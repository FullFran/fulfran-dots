# Ghostty Configuration - Tokyo Night / Vim-style
# https://ghostty.org/docs/config

# ============================================
# THEME - Tokyo Night
# ============================================
theme = TokyoNight Night

# ============================================
# FONT
# ============================================
font-family = JetBrainsMono Nerd Font
font-size = 13

# ============================================
# WINDOW AND APPEARANCE
# ============================================
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-decoration = none
window-theme = dark
background-opacity = 0.95

# Tabs at the bottom (Linux GTK)
gtk-tabs-location = bottom
gtk-wide-tabs = false

# Custom CSS for tabs
gtk-custom-css = .notebook tab { background: rgba(30, 30, 46, 0.6); border: none; padding: 2px 8px; } .notebook tab:checked { background: rgba(59, 66, 97, 0.8); }

# ============================================
# CURSOR - Vim style
# ============================================
cursor-style = block
cursor-style-blink = false
cursor-color = #7aa2f7
cursor-text = #1a1b26

# ============================================
# SCROLLBACK
# ============================================
scrollback-limit = 5000000

# ============================================
# KEYBINDINGS - Vim / tmux passthrough
# ============================================
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

keybind = ctrl+shift+f=unbind

keybind = ctrl+shift+up=scroll_page_up
keybind = ctrl+shift+down=scroll_page_down
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+end=scroll_to_bottom

keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

keybind = ctrl+shift+n=new_window

# Pass everything else to tmux
keybind = ctrl+shift+t=unbind
keybind = ctrl+shift+w=unbind
keybind = ctrl+backspace=text:\x17
keybind = ctrl+tab=unbind
# Ghostty sees Ctrl+Shift+Tab correctly, but the default terminal encoding is
# ambiguous for tmux with extended-keys disabled. Send tmux prefix (Ctrl+Space)
# plus `p`, which is tmux's previous-window binding.
keybind = ctrl+shift+tab=text:\x00p
keybind = ctrl+alt+h=unbind
keybind = ctrl+alt+j=unbind
keybind = ctrl+alt+k=unbind
keybind = ctrl+alt+l=unbind
keybind = ctrl+shift+r=unbind
keybind = ctrl+shift+d=unbind
keybind = ctrl+shift+h=unbind
keybind = ctrl+shift+j=unbind
keybind = ctrl+shift+k=unbind
keybind = ctrl+shift+l=unbind
keybind = ctrl+shift+z=unbind
keybind = ctrl+shift+s=unbind
keybind = ctrl+shift+g=unbind
keybind = ctrl+shift+a=unbind
keybind = ctrl+shift+escape=unbind
keybind = ctrl+shift+n=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+b=unbind
keybind = ctrl+shift+m=unbind

keybind = ctrl+shift+comma=reload_config

# ============================================
# MOUSE
# ============================================
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# ============================================
# SHELL INTEGRATION
# ============================================
# Launch tmux; new panes inherit $SHELL (zsh via nix, declared in tmux.conf).
command = tmux new-session -As main
shell-integration = detect
shell-integration-features = cursor,sudo,title

# ============================================
# PERFORMANCE
# ============================================
font-feature = -calt, -liga, -dlig

adjust-cell-height = 10%

# ============================================
# FOCUS AND VISUALS
# ============================================
unfocused-split-opacity = 0.9
split-divider-color = #3b4261

# ============================================
# ADVANCED
# ============================================
confirm-close-surface = true
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# ============================================
# PRODUCTIVITY
# ============================================
cursor-click-to-move = true
link-previews = true

# ============================================
# TRANSPARENCY AND BLUR (Linux)
# ============================================
background-blur = false
